{
  "model_id": "{{MODEL_ID}}",
  "model_name": "{{MODEL_NAME}}",
  "model_type": "api",
  "provider": "{{PROVIDER}}",
  "api_endpoint": "{{API_ENDPOINT}}",
  "api_version": "{{API_VERSION}}",
  "authentication": {
    "type": "bearer_token",
    "env_var_name": "{{API_KEY_ENV_VAR}}",
    "rotation_policy": "90_days"
  },
  "default_parameters": {
    "model": "{{MODEL_ID}}",
    "temperature": 0.7,
    "top_p": 1.0,
    "max_tokens": 4096,
    "frequency_penalty": 0,
    "presence_penalty": 0
  },
  "rate_limits": {
    "requests_per_minute": {{RPM_LIMIT}},
    "tokens_per_minute": {{TPM_LIMIT}},
    "daily_requests": {{DAILY_LIMIT}}
  },
  "cost": {
    "input_tokens_per_1k": {{INPUT_COST}},
    "output_tokens_per_1k": {{OUTPUT_COST}},
    "currency": "USD"
  },
  "capabilities": ["{{CAPABILITY_1}}", "{{CAPABILITY_2}}"],
  "security": {
    "require_ssl": true,
    "allowed_domains": ["{{ALLOWED_DOMAIN}}"],
    "data_residency": "{{DATA_RESIDENCY}}"
  },
  "metadata": {
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}",
    "version": "1.0",
    "tags": ["api", "cloud-hosted"]
  }
}
